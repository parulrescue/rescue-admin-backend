# =============================================================================
# Admin Backend Environment Configuration
# =============================================================================

APP_ENV=local
NODE_ENV=development

PORT=5556
TIMEZONE=Asia/Kolkata

# Database (same DB as user backend)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=animal_rescue

# Security — MUST use different JWT_SECRET from user backend
JWT_SECRET=admin-secret-key-change-in-production
JWT_EXPIRES_IN=48h
BCRYPT_ROUNDS=12
AES_SECRET_KEY=32CharSecretKeyHere_ExactlyThis!

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_app_password
SMTP_FROM="Animal Rescue <noreply@example.com>"

# Uploads
UPLOAD_DIR=./uploads

# CORS
ADMIN_FRONTEND_URL=http://localhost:5174
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug
LOG_ERRORS=true
LOG_SUCCESS=false
LOG_FILE_ENABLED=true
LOG_DIR=./logs
